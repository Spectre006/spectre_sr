PORT=3000

# Supabase pooler URL (recommended for IPv4-compatible access)
# Example:
# postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# SSL settings
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
# Optional PEM certificate content (single line with \n)
DB_SSL_CA=

# Table and column names
DB_TABLE=SR
DB_COL_TICKETID=TICKETID
DB_COL_DESCRIPTION=DESCRIPTION
DB_COL_STATUS=STATUS

# SOAP namespace for WSDL and request/response payloads (Maximo-compatible default)
SOAP_NAMESPACE=http://www.ibm.com/maximo
